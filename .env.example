# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required for OpenRouter-based drivers (codex_openrouter, openrouter_gpt5)
OPENROUTER_API_KEY=

# Required for W&B logging (logger: wandb)
WANDB_API_KEY=

# Optional: DeepSeek API (if using DeepSeek provider)
# DEEPSEEK_API_KEY=
